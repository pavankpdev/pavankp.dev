---
import SectionHeader from "./SectionHeader.astro";
import { SKILLS } from "../data";
---

<section id="skills" class="section-pad site-shell">
  <SectionHeader
    eyebrow="Skills"
    title="A practical stack for AI products and dependable platforms."
    description="The emphasis is backend depth, cloud operations, and product-minded AI integration rather than tool collecting."
  />

  <div class="grid gap-4 md:grid-cols-2">
    {SKILLS.map((group) => (
      <article class="panel p-6">
        <div class="flex items-start justify-between gap-6">
          <h3 class="font-serif text-3xl leading-none">{group.category}</h3>
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[var(--accent)]"></span>
        </div>
        <p class="body-copy mt-4">{group.summary}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {group.items.map((item) => <span class="chip">{item}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>
