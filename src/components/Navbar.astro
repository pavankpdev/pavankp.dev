---
import { SITE } from "../data";

const navItems = [
  { href: "#about", label: "About" },
  { href: "#skills", label: "Skills" },
  { href: "#experience", label: "Experience" },
  { href: "#writing", label: "Writing" },
  { href: "#contact", label: "Contact" },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-[var(--line)] bg-[rgba(247,245,239,0.86)] backdrop-blur-xl">
  <nav class="site-shell flex h-16 items-center justify-between gap-6" aria-label="Primary">
    <a href="/" class="flex items-center gap-3 no-underline" aria-label={`${SITE.name} home`}>
      <span class="flex h-8 w-8 items-center justify-center rounded-[8px] border border-[var(--ink)] bg-[var(--ink)] text-sm font-bold text-[var(--paper)]">
        P
      </span>
      <span class="font-bold">{SITE.name}</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {navItems.map((item) => (
        <a class="text-sm text-[var(--muted)] no-underline transition-colors hover:text-[var(--ink)]" href={item.href}>
          {item.label}
        </a>
      ))}
    </div>

    <a class="button button-secondary hidden h-10 min-h-10 px-4 text-sm sm:inline-flex" href={`mailto:${SITE.email}`}>
      Let's talk
    </a>
  </nav>
</header>
