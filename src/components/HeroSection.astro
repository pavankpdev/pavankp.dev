---
import { SITE, SOCIALS } from "../data";
---

<section class="profile-hero site-shell">
  <div class="hero-kicker">Pavan Kumar</div>

  <div class="hero-grid">
    <h1>{SITE.role}</h1>
    <p class="hero-line">{SITE.headline}</p>
    <p class="hero-context">{SITE.summary}</p>

    <div class="hero-actions" aria-label="Primary links">
      <div class="social-links">
        {SOCIALS.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer">{social.label}</a>
        ))}
      </div>
    </div>
  </div>
</section>
