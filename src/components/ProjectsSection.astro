---
import SectionHeader from "./SectionHeader.astro";
import { PROJECTS } from "../data";
---

<section id="projects" class="section-pad border-y border-[var(--line)] bg-[rgba(255,255,255,0.36)]">
  <div class="site-shell">
    <SectionHeader
      eyebrow="Projects"
      title="Selected systems with backend, cloud, and product weight."
    />

    <div class="grid gap-4 lg:grid-cols-3">
      {PROJECTS.map((project) => (
        <article class="panel p-6">
          <h3 class="font-serif text-3xl leading-none">{project.name}</h3>
          <p class="body-copy mt-5">{project.description}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {project.stack.map((item) => <span class="chip">{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
