---
import SectionHeader from "./SectionHeader.astro";
import { EXPERIENCE } from "../data";
---

<section id="experience" class="section-pad site-shell">
  <SectionHeader
    eyebrow="Experience"
    title="Product engineering across AI, cloud, data, and backend-heavy systems."
  />

  <div class="grid gap-4">
    {EXPERIENCE.map((exp) => (
      <article class="panel grid gap-5 p-6 md:grid-cols-[240px_1fr]">
        <div>
          <p class="font-mono text-sm text-[var(--accent-strong)]">{exp.duration}</p>
          <h3 class="mt-3 text-xl font-bold leading-tight">{exp.role}</h3>
          <p class="mt-1 text-[var(--muted)]">{exp.company}</p>
        </div>
        <div>
          <p class="text-lg leading-relaxed">{exp.description}</p>
          <ul class="mt-5 grid gap-3">
            {exp.impact.map((item) => (
              <li class="grid grid-cols-[12px_1fr] gap-3 text-sm leading-6 text-[var(--muted)]">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[var(--signal)]"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>
