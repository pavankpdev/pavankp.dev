---
import { EXPERIENCE } from "../data";

const visibleExperience = EXPERIENCE.slice(0, 3);
const remainingExperience = EXPERIENCE.slice(3);
---

<section class="site-shell profile-section" aria-labelledby="experience-title">
  <h2 id="experience-title">Experience</h2>

  <div class="experience-list">
    {visibleExperience.map((exp) => (
      <article class="experience-item">
        <div class="experience-meta">
          <h3>{exp.company}</h3>
          <p>{exp.role}</p>
          {exp.employment && <span>{exp.employment}</span>}
          <time>{exp.duration}</time>
          {exp.location && <small>{exp.location}</small>}
        </div>
        <ul>
          {exp.impact.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    ))}
  </div>

  {remainingExperience.length > 0 && (
    <div class="more-experience">
      <input class="more-toggle" id="experience-more" type="checkbox" />
      <div class="experience-list more-experience-list">
        {remainingExperience.map((exp) => (
          <article class="experience-item">
            <div class="experience-meta">
              <h3>{exp.company}</h3>
              <p>{exp.role}</p>
              {exp.employment && <span>{exp.employment}</span>}
              <time>{exp.duration}</time>
              {exp.location && <small>{exp.location}</small>}
            </div>
            <ul>
              {exp.impact.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
      <label class="more-experience-control" for="experience-more">
        <span class="more-label">View full experience</span>
        <span class="less-label">Show less</span>
      </label>
    </div>
  )}
</section>
