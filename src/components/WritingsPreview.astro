---
import type { ExternalPost } from "../lib/rss";

interface Props {
  posts: ExternalPost[];
  hasMore?: boolean;
}

const { posts, hasMore = false } = Astro.props;
---

<section class="site-shell profile-section writing-section" aria-labelledby="writing-title">
  <h2 id="writing-title">Writing</h2>

  {posts.length > 0 && (
    <>
      <div class="writing-list">
        {posts.map((post) => (
          <a href={post.url} target="_blank" rel="noopener noreferrer">
            <span>{post.title}</span>
            <time>{post.date}</time>
          </a>
        ))}
      </div>
      {hasMore && <a class="writing-more" href="/blogs">View More</a>}
    </>
  )}

  {posts.length === 0 && <p class="empty-writing">No blogs published yet.</p>}
</section>
