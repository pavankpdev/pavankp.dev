---
import Footer from '../components/Footer.astro';
import '../styles/index.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pavan Kumar | Full Stack AI Engineer',
  description = 'Full Stack AI Engineer building AI systems, scalable backend infrastructure, distributed systems, cloud platforms, and performant frontend experiences.',
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://pavankp.dev';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL('/og-image.svg', siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Pavan Kumar" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#080a08" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Pavan Kumar" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Pavan Kumar, Full Stack AI Engineer" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Pavan Kumar, Full Stack AI Engineer" />
    <meta name="twitter:creator" content="@pavank38" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#d8e36b" />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen overflow-x-hidden">
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
